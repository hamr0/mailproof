# mailproof — example configuration
#
# mailproof itself takes config by INJECTION, not from the environment:
#
#   const core = require('mailproof').create({
#     dataDir, domain, mtaHostname, sendmailBin, otsBin, gitBin, ...
#   });
#
# This file is a reference template for an operator/consumer that maps env
# vars to that create() call (12-factor; see AGENT_RULES). Copy to a real
# env file your process loader reads, and feed the values into create().
# Defaults shown are production-sensible.

# --- Identity (required) ---------------------------------------------------
# Mail domain events live under; appears in plus-tag addresses and signatures.
MAILPROOF_DOMAIN=example.com
# Public hostname of the MTA (MX target).
MAILPROOF_MTA_HOSTNAME=mail.example.com

# --- Storage (required) ----------------------------------------------------
# Root for event JSON ({dataDir}/events) and per-event git repos
# ({dataDir}/repos). Must be writable by the process; back it up.
MAILPROOF_DATA_DIR=/var/lib/mailproof

# --- Transport -------------------------------------------------------------
# Postfix's drop-in sendmail; receives raw RFC-822 on stdin.
MAILPROOF_SENDMAIL_BIN=/usr/sbin/sendmail
# git binary used by simple-git for the per-event ledger.
MAILPROOF_GIT_BIN=/usr/bin/git

# --- OpenTimestamps (optional) ---------------------------------------------
# Path to the `ots` CLI. Leave unset to disable Bitcoin anchoring entirely —
# the git commit chain is the primary tamper-evidence; OTS is accept-with-flag.
# MAILPROOF_OTS_BIN=/usr/local/bin/ots

# --- Inbound limits --------------------------------------------------------
# Cap bytes scanned for the header pre-filter (humans-only gate).
MAILPROOF_MAX_HEADER_BYTES=65536

# --- Lifecycle sweep thresholds (call core.sweep() from cron/systemd timer) -
# Delete never-activated events after this many hours (kill zombie records).
MAILPROOF_ACTIVATION_TTL_HOURS=72
# Days past the reference clock before a one-shot nudge emails the initiator.
MAILPROOF_OVERDUE_NUDGE_DAYS=14
# Days past the reference clock before an incomplete event is auto-archived
# (reversible; never auto-completed).
MAILPROOF_ARCHIVE_DAYS=45

# --- Logging ---------------------------------------------------------------
# Treat logs as an event stream to stdout (12-factor).
MAILPROOF_LOG_STDOUT=true
# Optional file sink in addition to stdout.
# MAILPROOF_LOG_FILE=/var/log/mailproof/mailproof.log
