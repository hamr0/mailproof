{
  // Dev-only types toolchain (LIBRARY_CONVENTIONS §2). mailproof ships vanilla
  // JS + JSDoc with NO build step for consumers; tsc only (a) checks the JSDoc
  // against the implementation (checkJs) and (b) generates the shipped .d.ts
  // from it. The JSDoc is the single source of truth.
  //
  // Anti-drift: the generated .d.ts are emitted to ./types, git-ignored, and
  // built fresh on publish (package.json `prepublishOnly`) — never committed,
  // so no stored artifact can go stale. Emitting to a separate dir (not next to
  // src/*.js) also means no .d.ts is ever both an input and an output, so the
  // declaration emit can't collide with its own prior output.
  //
  // Strictness: checkJs + `strictNullChecks`, NOT full `strict`. Full strict is
  // ~95% noImplicitAny annotation-noise over framework-agnostic params and ~5%
  // real null-safety; strictNullChecks keeps the 5% and drops the noise.
  //
  // `npm run typecheck` runs `tsc --noEmit` (check only); `npm run build:types`
  // runs `tsc` (emits the .d.ts to ./types).
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "./types",
    "rootDir": "./src",
    "module": "node16",
    "moduleResolution": "node16",
    "target": "es2022",
    "lib": ["es2022"],
    "types": ["node"],
    "skipLibCheck": true,
    "noEmitOnError": true,
    "strict": false,
    "strictNullChecks": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.js"],
  "exclude": ["types", "node_modules"]
}
