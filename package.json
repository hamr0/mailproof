{
  "name": "mailproof",
  "version": "1.3.0",
  "description": "Email-native multi-party coordination kernel: turns a promise made over email into proof. DKIM/DMARC-verified replies, a tamper-evident git ledger, workflow sequencing, and email triggers. Extracted from gitdone.",
  "type": "module",
  "main": "src/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "poc": "node poc/pipeline.cjs",
    "test": "node --test 'tests/unit/**/*.test.js' 'tests/integration/**/*.test.js'",
    "typecheck": "tsc --noEmit",
    "build:types": "tsc",
    "prepublishOnly": "npm run build:types"
  },
  "keywords": [
    "email",
    "dkim",
    "dmarc",
    "git",
    "ledger",
    "audit-trail",
    "tamper-evident",
    "workflow",
    "coordination",
    "multi-party",
    "verification",
    "vanilla-js",
    "nodejs"
  ],
  "author": "hamr0 <avoidaccess@msn.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hamr0/mailproof.git"
  },
  "bugs": {
    "url": "https://github.com/hamr0/mailproof/issues"
  },
  "homepage": "https://github.com/hamr0/mailproof#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "engines": {
    "node": ">=22.5"
  },
  "files": [
    "src/",
    "types/",
    "README.md",
    "mailproof.context.md",
    "OPS.md",
    "CHANGELOG.md",
    "config.example.env",
    "LICENSE",
    "NOTICE"
  ],
  "dependencies": {
    "mailauth": "^4.13.3",
    "mailparser": "^3.9.11"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "undici": "^7.28.0",
    "nodemailer": "^9.0.1"
  }
}
