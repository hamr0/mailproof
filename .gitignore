node_modules/
poc/.data/
*.log
.npmrc

# Generated TypeScript declarations — emitted from JSDoc by `npm run build:types`,
# git-ignored and built fresh on publish (prepublishOnly). Never committed, so
# the .d.ts can't drift from the JSDoc (LIBRARY_CONVENTIONS §2).
/types/
/src/**/*.d.ts
.claude/settings.local.json
.claude/stash/

# litectx local context index (sqlite + WAL) — never commit
.litectx/

# local friction telemetry — contains PII + cross-project session data, never publish
.claude/friction/
# local agent memory — not published
.claude/memory/

# Agent / IDE scratch — never commit (per hamr0 LIBRARY_CONVENTIONS §7)
.claude/
.litectx/
.idea/
